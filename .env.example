# Copy to `.env` and replace the placeholder password before running.
# `.env` is gitignored — never commit real credentials.
#
# NEO4J_AUTH is consumed by the neo4j container to provision the initial
# user/password. It MUST stay in sync with NEO4J_USER / NEO4J_PASSWORD,
# which Compose interpolates into the api service env and the neo4j
# healthcheck's cypher-shell command at parse time.

# Format: <user>/<password>
NEO4J_AUTH=neo4j/change-me-before-running

NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-before-running

# Origin the api allows via CORS. Must match where the browser loads the
# web UI from (the web service publishes on http://localhost:3000).
WEB_ORIGIN=http://localhost:3000
